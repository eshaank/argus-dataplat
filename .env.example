# Schwab Developer Portal → your app (Market Data Production)
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
# Must match the Callback URL on the app EXACTLY (scheme, host, port, path, slash).
# Must match the portal. For `oauth --serve-callback`, use a high port, e.g.:
#   SCHWAB_REDIRECT_URI=https://127.0.0.1:8182
# (register that exact string; changing it can require Schwab re-approval.)
# Manual paste flow: https://127.0.0.1 works if you copy the URL from the bar after redirect.
SCHWAB_REDIRECT_URI=https://127.0.0.1:8182



# After one-time `uv run python scripts/schwab_quotes_to_clickhouse.py oauth`, you can
# copy refresh_token from .schwab_token.json here if you prefer env-only (optional).
# SCHWAB_REFRESH_TOKEN=

# Where the OAuth script stores tokens (JSON)
SCHWAB_TOKEN_PATH=.schwab_token.json

# Comma-separated symbols for the test fetch (see QUOTE.md)
SCHWAB_SYMBOLS=AAPL,MSFT

# Local ClickHouse: docker compose -f docker-compose.clickhouse.yml up -d
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=local_dev_clickhouse
CLICKHOUSE_DATABASE=dataplat

# CLICKHOUSE_HOST=YOUR_CLICKHOUSE_CLOUD_HOST
# CLICKHOUSE_PORT=8443
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=REDACTED
# CLICKHOUSE_DATABASE=default


CH_CLOUD_HOST=
CH_CLOUD_PORT=8443
CH_CLOUD_USER=default
CH_CLOUD_PASSWORD=
CH_CLOUD_DATABASE=default


# Massive API Key
MASSIVE_API_KEY=
POLYGON_API_KEY=

# === SEC EDGAR (financials, insider trades, institutional holders) ===
# Required by SEC: identify yourself with name + email
SEC_EDGAR_USER_AGENT="YourName your@email.com"

# FRED (free key: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

#ThetaData 
 THETADATA_USERNAME=
 THETADATA_PASSWORD=
