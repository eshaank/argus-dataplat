# ============================================================
# Argus DataPlat — Environment Variables
# ============================================================
# Copy to .env and fill in your credentials:
#   cp .env.example .env
# ============================================================

# === Schwab (all ticker-level market data) ===
# Register at https://developer.schwab.com
# Requires both "Accounts and Trading Production" and "Market Data Production" APIs
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_REDIRECT_URI=https://127.0.0.1
SCHWAB_TOKENS_DB=.schwab_tokens.db

# === ClickHouse ===
# Local dev: docker compose up -d
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=local_dev_clickhouse
CLICKHOUSE_DATABASE=dataplat
CLICKHOUSE_SECURE=false
# For ClickHouse Cloud, use:
#   CLICKHOUSE_HOST=abc123.us-east-1.aws.clickhouse.cloud
#   CLICKHOUSE_PORT=8443
#   CLICKHOUSE_SECURE=true

# === Polygon (reference data + one-off 1-min backfill ONLY) ===
# NOT used for ongoing price data — Schwab is the sole source
POLYGON_API_KEY=

# === FRED (economic indicators) ===
FRED_API_KEY=
